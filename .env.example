# PathFinder — environment (example)
# 실제 값은 `.env.local`에 넣으세요. Next.js는 `.env.example`을 로드하지 않습니다.
# Copy this file to `.env.local` and fill in values. Never commit real secrets.

# Gemini (server-only; used by `src/app/api/ai-docent/route.ts`)
# 키 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# `GOOGLE_API_KEY`만 있어도 동일하게 인식합니다.

# 모델이 없다는 오류(404)면 `gemini-2.0-flash` 또는 `gemini-1.5-flash`로 바꿔 보세요.
GEMINI_MODEL=gemini-2.5-flash

# Optional: public API base for other backends
# NEXT_PUBLIC_API_BASE_URL=

# Kakao Maps / Local API
# JavaScript Key는 브라우저 지도 SDK용입니다. Kakao Developers > Platform > Web에 localhost/배포 도메인을 등록하세요.
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
# REST API Key는 서버 Route Handler에서만 사용합니다. NEXT_PUBLIC_ 접두사를 붙이지 마세요.
KAKAO_REST_API_KEY=
