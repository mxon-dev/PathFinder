# PathFinder — environment (example)
# 실제 값은 `.env.local`에 넣으세요. Next.js는 `.env.example`을 로드하지 않습니다.
# Copy this file to `.env.local` and fill in values. Never commit real secrets.

# Gemini (server-only; used by `src/app/api/ai-docent/route.ts`)
# 키 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# `GOOGLE_API_KEY`만 있어도 동일하게 인식합니다.

# 모델이 없다는 오류(404)면 `gemini-2.0-flash` 또는 `gemini-1.5-flash`로 바꿔 보세요.
GEMINI_MODEL=gemini-2.5-flash

# 공공데이터포털 (서버 전용 — 채팅 의도에 맞는 오픈API 호출)
# 발급·신청: https://www.data.go.kr
# 포털 마이페이지에서 받는 "Encoding" 키(%2F·%2B 포함) 또는 "Decoding" 키 어느 쪽이든 됩니다.
# 코드가 `%`를 보면 그대로 사용하고, 아니면 자동 인코딩합니다.
PUBLIC_DATA_SERVICE_KEY=

# 도시공원 API 전체 URL (미설정 시 아래 기본 URL)
# 포털: https://www.data.go.kr/data/15012890/standard.do — 활용신청 필요
# PUBLIC_DATA_PARK_ENDPOINT=https://api.data.go.kr/openapi/tn_pubr_public_cty_park_info_api

# 길·산책로 — 전국길관광정보표준데이터 openapi (미설정 시 아래 기본 URL)
# 포털: https://www.data.go.kr/data/15017321/standard.do — 활용신청 필요
# PUBLIC_DATA_TRAIL_ENDPOINT=https://api.data.go.kr/openapi/tn_pubr_public_stret_tursm_info_api

# 길 API는 기본 `type=json`. 일부만 _type=json 이면:
# PUBLIC_DATA_TRAIL_RESPONSE_FORMAT_PARAM=_type

# Kakao 주소·키워드 검색으로 시작·종료·경로정보 경유지 좌표 보강
# # 지오코딩 시도 상한(많을수록 느리지만 빈 목록 방지). 서울 우선 정렬 후 반경 내 코스가 나올 때까지 시도
PUBLIC_DATA_TRAIL_GEOCODE_MAX_ATTEMPTS=24
# PUBLIC_DATA_TRAIL_WAYPOINT_LIMIT=8
# PUBLIC_DATA_TRAIL_PAGE_SIZE=200

# 일부 API는 _type=json 사용
# PUBLIC_DATA_RESPONSE_FORMAT_PARAM=_type

# PUBLIC_DATA_PAGE_SIZE=120
# PUBLIC_DATA_NEAR_RADIUS_KM=40

# Optional: public API base for other backends
# NEXT_PUBLIC_API_BASE_URL=

# Kakao Maps / Local API
# [필수] 새 앱 만들었다면 Kakao Developers → 내 애플리케이션 → 제품 설정에서
#   「지도/로컬」(OPEN_MAP_AND_LOCAL) 을 ON (꺼져 있으면 403 disabled OPEN_MAP_AND_LOCAL)
# [필수] Platform → Web → 사이트 도메인 등록
#   - PC: http://localhost:3000
#   - 휴대폰(Wi‑Fi): http://192.168.x.x:3000
# 앱 키 → REST API 키 = KAKAO_REST_API_KEY, JavaScript 키 = NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
# LAN에서 dev 접속 시 Next.js _next 리소스 허용 (호스트:포트만, 프로토콜 제외). 예: 192.168.0.13:3000
# NEXT_PUBLIC_DEV_ORIGIN=192.168.0.13:3000
# REST API Key는 서버 Route Handler에서만 사용합니다. NEXT_PUBLIC_ 접두사를 붙이지 마세요.
KAKAO_REST_API_KEY=
